# CropRadar – Environment Variables
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.

# ---- Vision AI (use one or both) ----
GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here   # uncomment to use GPT-4o instead

# ---- Telegram bot ----
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ---- Backend URL (used by bot and dashboard) ----
CROPRADAR_API_URL=http://localhost:8000
