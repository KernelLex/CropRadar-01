# CropRadar – Environment Variables
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.

# ---- Vision AI (use one or both) ----
GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here   # uncomment to use GPT-4o instead

# ---- Telegram bot ----


# ---- WhatsApp bot (Twilio Sandbox) ----
# Get these from https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# Port for the Flask webhook server
WHATSAPP_PORT=5001

# ---- Backend URL (used by bot and dashboard) ----
CROPRADAR_API_URL=http://localhost:8000

