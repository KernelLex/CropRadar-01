# CropRadar – Environment Variables
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.

# ---- Vision AI (use one or both) ----
GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here   # uncomment to use GPT-4o instead

# ---- Telegram bot ----
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ---- Admin dashboard ----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cropradar123

# ---- Push notifications (Firebase FCM V1) ----
# Place your service account JSON at: firebase-adminsdk-account.json
# (Download from Firebase Console → Project Settings → Service accounts → Generate key)
# No env var needed — the file is read automatically by notifier.py

# ---- WhatsApp bot (Twilio Sandbox) ----
# Get these from https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# Port for the Flask webhook server
WHATSAPP_PORT=5001

# ---- Backend URL (used by bot and dashboard) ----
CROPRADAR_API_URL=http://localhost:8000

