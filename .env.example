# CropRadar – Environment Variables
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.

# ---- Vision AI (use one or both) ----
GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here   # uncomment to use GPT-4o instead

# ---- Telegram bot ----
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ---- WhatsApp bot (Meta Cloud API) ----
# Get these from https://developers.facebook.com → your App → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
# Choose any secret string — you'll paste this into Meta's webhook config
WHATSAPP_VERIFY_TOKEN=cropradar_verify_secret
# Port for the Flask webhook server
WA_BOT_PORT=5000

# ---- Backend URL (used by bot and dashboard) ----
CROPRADAR_API_URL=http://localhost:8000
